{
  "name": "rijalclubweb-backend",
  "version": "1.0.0",
  "description": "Rijal Club content API and admin panel",
  "main": "server/index.js",
  "scripts": {
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --config vite.config.mjs",
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "build:web": "vite build --config vite.config.mjs",
    "build": "npm run build:web",
    "start": "NODE_ENV=production node server/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "zod": "^4.3.6"
  }
}
