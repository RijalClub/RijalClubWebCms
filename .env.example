# Server
NODE_ENV=development
PORT=4000
API_BASE_PATH=/api
ADMIN_ORIGIN=http://localhost:5173
TRUST_PROXY=false

# Auth
JWT_SECRET=replace-with-a-long-secret
JWT_EXPIRES_IN=8h
AUTH_COOKIE_NAME=rijal_admin_token
BOOTSTRAP_MASTER_USERNAME=master
BOOTSTRAP_MASTER_DISPLAY_NAME="Master Admin"
BOOTSTRAP_MASTER_PASSWORD=change-this-password
AUTH_STORE_PATH=.admin/users.json

# Public content API key gate (optional). Note: this is not strong security on its own.
CONTENT_PUBLIC_KEY=replace-with-public-key
CONTENT_PUBLIC_CACHE_SECONDS=60
GITHUB_COMMITTER_NAME=RijalEditBot
GITHUB_COMMITTER_EMAIL=rijaleditbot@users.noreply.github.com

# Content files list (optional; defaults to all core json files)
# CONTENT_FILES=profile.json,links.json,announcements.json,blog.json,prayer.json,store.json,quran.json,hadith.json,contact.json,cache.json

# Private GitHub repo for content JSON + auth store
CONTENT_GITHUB_OWNER=RijalClub
CONTENT_GITHUB_REPO=RijalClubWebContent
CONTENT_GITHUB_BRANCH=main
CONTENT_GITHUB_BASE_PATH=content
CONTENT_GITHUB_TOKEN=github_pat_with_repo_access

# Public GitHub repo for uploaded media
MEDIA_GITHUB_OWNER=RijalClub
MEDIA_GITHUB_REPO=RijalClubWebMedia
MEDIA_GITHUB_BRANCH=main
MEDIA_GITHUB_BASE_PATH=assets
MEDIA_GITHUB_TOKEN=github_pat_with_repo_access
MEDIA_PUBLIC_BASE_URL=https://raw.githubusercontent.com/RijalClub/RijalClubWebMedia/main
UPLOAD_MAX_BYTES=8388608

# Frontend (Vite)
VITE_API_BASE_URL=/api
